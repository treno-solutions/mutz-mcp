{
  "name": "belex-scraper",
  "version": "0.1.0",
  "description": "Scraper for Bern canton tax law texts from belex.sites.be.ch",
  "type": "module",
  "scripts": {
    "scrape": "tsx src/index.ts",
    "scrape:de": "tsx src/index.ts --lang de",
    "scrape:fr": "tsx src/index.ts --lang fr",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "tsc --noEmit && eslint src && vitest run"
  },
  "dependencies": {
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.3",
    "eslint": "^10.2.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
